/ 3\n    return dict(planning_score=round(plan_score,4), inhibition_score=round(inhib_score,4),\n                switching_score=round(post_acc,4), exec_score=round(exec_score,4),\n                trap_recognition_rate=round(trap_rate,4),\n                pre_switch_accuracy=round(pre_acc,4), post_switch_accuracy=round(post_acc,4),\n                switch_cost=round(pre_acc-post_acc,4))\n\n\ndef print_score_report(scores, model_name='Model'):\n    sep = '='*54\n    print(f'\\n{sep}')\n    print(f'  CortexPilot Executive Control — {model_name}')\n    print(sep)\n    print(f\"  Planning Score      : {scores['planning_score']:.2%}\")\n    print(f\"  Inhibition Score    : {scores['inhibition_score']:.2%}\")\n    print(f\"  Switching Score     : {scores['switching_score']:.2%}\")\n    print(f\"  ── Trap Recog. Rate : {scores['trap_recognition_rate']:.2%}\")\n    print(f\"  ── Pre-switch Acc   : {scores['pre_switch_accuracy']:.2%}\")\n    print(f\"  ── Post-switch Acc  : {scores['post_switch_accuracy']:.2%}\")\n    print(f\"  ── Switch Cost      : {scores['switch_cost']:.2%}\")\n    print(sep)\n    print(f\"  ★  ExecScore        : {scores['exec_score']:.2%}\")\n    print(f'{sep}\\n')\n\nprint('✅ Scoring utilities defined')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-17T09:24:59.113688Z","iopub.execute_input":"2026-04-17T09:24:59.114305Z","iopub.status.idle":"2026-04-17T09:24:59.127670Z","shell.execute_reply.started":"2026-04-17T09:24:59.114270Z","shell.execute_reply":"2026-04-17T09:24:59.126522Z"}},"outputs":[{"name":"stdout","text":"✅ Scoring utilities defined\n","output_type":"stream"}],"execution_count":10},{"id":"60b963ae-f1c0-4000-b6f5-d664c3b7abc1","cell_type":"markdown","source":"## Cell 9 — Task 1: `ExecPlan_Benchmark`","metadata":{}},{"id":"81efe8d5-cbc4-49cf-9744-22f6f51679a7","cell_type":"code","source":"@kbench.task(\n    name='ExecPlan_Benchmark',\n    description=(\n        'Evaluates multi-step planning under explicit constraints and re-planning ability. '\n        'Models must propose valid ordered sequences (scheduling, routing, resource packing) '\n        'that satisfy all stated rules, and correctly update those plans when a constraint changes.'\n    )\n)\ndef ExecPlan_Benchmark(llm, max_items: int = None):\n    def _normalize_text(v: str) -> str:\n        v = str(v).strip().lower()\n        v = v.replace('→', '->')\n        v = re.sub(r'\\s+', ' ', v)\n        return v.strip(' .')\n\n    def _arrow_tuple(v: str):\n        t = _normalize_text(v)\n        if '->' not in t:\n            return None\n        parts = [p.strip() for p in t.split('->') if p.strip()]\n        return tuple(parts) if parts else None\n\n    def _item_set(v: str):\n        t = _normalize_text(v)\n        if ',' not in t and ';' not in t:\n            return None\n        parts = [p.strip() for p in re.split(r'[,;]', t) if p.strip()]\n        return tuple(sorted(parts)) if parts else None\n\n    def _is_plan_match(answer: str, valid_sequences):\n        ans_text = _normalize_text(answer)\n        ans_arrow = _arrow_tuple(answer)\n        ans_items = _item_set(answer)\n\n        valid_texts = {_normalize_text(v) for v in valid_sequences}\n        if ans_text in valid_texts:\n            return True\n\n        valid_arrows = {_arrow_tuple(v) for v in valid_sequences}\n        valid_arrows.discard(None)\n        if ans_arrow is not None and ans_arrow in valid_arrows:\n            return True\n\n        valid_items = {_item_set(v) for v in valid_sequences}\n        valid_items.discard(None)\n        if ans_items is not None and ans_items in valid_items:\n            return True\n\n        return False\n\n    results = []\n    df = df_plan.head(max_items) if max_items else df_plan\n\n    for _, row in df.iterrows():\n        item_id = row['item_id']\n        gold = str(row['gold_action']).strip()\n        meta = row['gold_meta'] if isinstance(row['gold_meta'], dict) else {}\n        valid_seqs = [s.strip() for s in meta.get('valid_sequences', [gold])]\n\n        base_prompt = (\n            f\"{row['prompt']}\\n\\n\"\n            \"--- SOLVE CHECKLIST ---\\n\"\n            \"1) Extract constraints from the prompt.\\n\"\n            \"2) Draft a candidate plan.\\n\"\n            \"3) Verify every constraint is satisfied.\\n\"\n            \"4) Return final answer only in required JSON schema.\\n\\n\"\n            \"--- OUTPUT FORMAT ---\\n\"\n            \"Return ONLY a valid JSON object (no extra text, no code fences) with keys:\\n\"\n            '  \"final_answer\", \"plan_steps\" (list), \"respects_constraints\" (bool), '\n            '\"confidence_score\" (0-100), \"reasoning\"'\n        )\n\n        attempt_prompt = base_prompt\n        response = None\n        parse_error = None\n        plan_valid = False\n\n        for attempt in range(2):\n            raw = llm.prompt(attempt_prompt)\n            cleaned = clean_json_response(raw)\n            try:\n                response = PlanningSchema(**json.loads(cleaned))\n                parse_error = None\n            except Exception as exc:\n                parse_error = exc\n                if attempt == 0:\n                    attempt_prompt = (\n                        base_prompt\n                        + \"\\n\\nYour previous output was invalid JSON/schema. \"\n                        + \"Return strictly valid JSON with the required keys only.\"\n                    )\n                    continue\n                break\n\n            plan_valid = _is_plan_match(response.final_answer, valid_seqs)\n            if plan_valid:\n                break\n\n            if attempt == 0:\n                attempt_prompt = (\n                    base_prompt\n                    + \"\\n\\nYour previous final_answer did not satisfy all constraints. \"\n                    + \"Re-check constraints and return a corrected plan.\"\n                )\n\n        if response is None:\n            kbench.assertions.assert_true(False, expectation=f'[{item_id}] Parse error: {parse_error}')\n            results.append({'item_id': item_id, 'plan_valid': False, 'confidence': 0})\n            continue\n\n        kbench.assertions.assert_true(\n            plan_valid,\n            expectation=f'[{item_id}] Wrong sequence. Got: {response.final_answer!r}. Expected: {valid_seqs}'\n        )\n\n        results.append({\n            'item_id': item_id,\n            'plan_valid': plan_valid,\n            'confidence': response.confidence_score,\n            'got': response.final_answer,\n        })\n\n    total = len(results)\n    valid = sum(1 for r in results if r.get('plan_valid'))\n    acc = (valid / total) if total else 0\n    print(f'[ExecPlan_Benchmark] Planning Accuracy: {acc:.2%} ({valid}/{total})')\n\n    # Keep records for notebook-side scoring while returning a kbench-compatible task result.\n    globals()['_last_execplan_records'] = results\n    return None\n\nprint('✅ ExecPlan_Benchmark defined')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-17T09:25:02.280723Z","iopub.execute_input":"2026-04-17T09:25:02.281113Z","iopub.status.idle":"2026-04-17T09:25:02.311428Z","shell.execute_reply.started":"2026-04-17T09:25:02.281086Z","shell.execute_reply":"2026-04-17T09:25:02.310323Z"}},"outputs":[{"name":"stdout","text":"✅ ExecPlan_Benchmark defined\n","output_type":"stream"}],"execution_count":11},{"id":"42fba4b3-58f4-4894-997b-c43908f3f23e","cell_type":"markdown","source":"## Cell 10 — Task 2: `ExecInhibit_Benchmark`","metadata":{}},{"id":"a98ecf85-2817-43b7-b749-30684e6ac7ac","cell_type":"code","source":"@kbench.task(\n    name='ExecInhibit_Benchmark',\n    description=(\n        'Evaluates inhibitory control (habit override). Each item contains a trap: '\n        'a salient, intuitively attractive answer that is incorrect. '\n        'Models must resist the habitual shortcut and produce the normatively correct answer.'\n    )\n)\ndef ExecInhibit_Benchmark(llm, max_items: int = None, prompt_variant: str = 'A'):\n    results = []\n    df = df_inhibit.head(max_items) if max_items else df_inhibit\n\n    variant = (prompt_variant or 'A').strip().upper()\n    if variant not in {'A', 'B'}:\n        variant = 'A'\n\n    for _, row in df.iterrows():\n        item_id = row['item_id']\n        gold    = str(row['gold_action']).strip().lower()\n\n        if variant == 'A':\n            base_prompt = (\n                f\"{row['prompt']}\\n\\n\"\n                \"--- INHIBITION CHECKLIST ---\\n\"\n                \"1) Identify the intuitive trap answer.\\n\"\n                \"2) Reject it explicitly.\\n\"\n                \"3) Compute/verify the correct answer.\\n\"\n                \"4) Output only valid JSON.\\n\\n\"\n                \"--- OUTPUT FORMAT ---\\n\"\n                \"Return ONLY a valid JSON object (no extra text, no code fences) with keys:\\n\"\n                '  \"final_answer\", \"is_trap_recognized\" (bool), '\n                '\"rejected_habitual_answer\", \"confidence_score\" (0-100), \"reasoning\"'\n            )\n        else:\n            base_prompt = (\n                f\"{row['prompt']}\\n\\n\"\n                \"--- SAFETY-FIRST REASONING ---\\n\"\n                \"Pause before answering. The obvious answer may be wrong.\\n\"\n                \"Do a quick counter-check and only then produce the final answer.\\n\\n\"\n                \"--- OUTPUT FORMAT ---\\n\"\n                \"Return ONLY a valid JSON object (no extra text, no code fences) with keys:\\n\"\n                '  \"final_answer\", \"is_trap_recognized\" (bool), '\n                '\"rejected_habitual_answer\", \"confidence_score\" (0-100), \"reasoning\"'\n            )\n\n        attempt_prompt = base_prompt\n        response = None\n        parse_error = None\n        correct = False\n\n        for attempt in range(2):\n            raw = llm.prompt(attempt_prompt)\n            cleaned = clean_json_response(raw)\n            try:\n                response = InhibitionSchema(**json.loads(cleaned))\n                parse_error = None\n            except Exception as exc:\n                parse_error = exc\n                if attempt == 0:\n                    attempt_prompt = (\n                        base_prompt\n                        + \"\\n\\nYour previous output was invalid JSON/schema. \"\n                        + \"Return strictly valid JSON with the required keys only.\"\n                    )\n                    continue\n                break\n\n            correct = response.final_answer.strip().lower() == gold\n            trap_ok = bool(response.is_trap_recognized)\n            if correct and trap_ok:\n                break\n\n            if attempt == 0:\n                attempt_prompt = (\n                    base_prompt\n                    + \"\\n\\nYour previous answer was incorrect or trap handling was weak. \"\n                    + \"Re-check the lure and correct the final_answer.\"\n                )\n\n        if response is None:\n            kbench.assertions.assert_true(False, expectation=f'[{item_id}] Parse error: {parse_error}')\n            results.append({'item_id': item_id, 'correct': False, 'trap_recognized': False, 'confidence': 0})\n            continue\n\n        kbench.assertions.assert_true(\n            correct,\n            expectation=f'[{item_id}] Fell for trap. Got: {response.final_answer!r}. Expected: {gold!r}'\n        )\n        kbench.assertions.assert_true(\n            response.is_trap_recognized,\n            expectation=f'[{item_id}] Trap not recognized.'\n        )\n\n        results.append({\n            'item_id': item_id,\n            'correct': correct,\n            'trap_recognized': response.is_trap_recognized,\n            'confidence': response.confidence_score,\n        })\n\n    n = len(results)\n    n_correct = sum(1 for r in results if r.get('correct'))\n    n_trap = sum(1 for r in results if r.get('trap_recognized'))\n    inhib = (n_correct / n) if n else 0\n    trap = (n_trap / n) if n else 0\n    print(f'[ExecInhibit_Benchmark] Variant:            {variant}')\n    print(f'[ExecInhibit_Benchmark] Inhibition Score:   {inhib:.2%} ({n_correct}/{n})')\n    print(f'[ExecInhibit_Benchmark] Trap Recognition:   {trap:.2%}')\n\n    globals()['_last_execinhibit_records'] = results\n    return None\n\nprint('✅ ExecInhibit_Benchmark defined')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-17T10:29:02.417478Z","iopub.execute_input":"2026-04-17T10:29:02.418518Z","iopub.status.idle":"2026-04-17T10:29:02.442085Z","shell.execute_reply.started":"2026-04-17T10:29:02.418484Z","shell.execute_reply":"2026-04-17T10:29:02.440855Z"}},"outputs":[{"name":"stdout","text":"✅ ExecInhibit_Benchmark defined\n","output_type":"stream"}],"execution_count":19},{"id":"c0783eb4-a0fa-438c-9e0b-7c1c79c25ec8","cell_type":"markdown","source":"## Cell 11 — Task 3: `ExecSwitch_Benchmark`","metadata":{}},{"id":"04926ca2-cfc7-4009-947e-a4c2af934efc","cell_type":"code","source":"@kbench.task(\n    name='ExecSwitch_Benchmark',\n    description=(\n        'Evaluates cognitive flexibility and task switching. Models must apply the '\n        'currently active rule, resisting perseveration on a previously stated rule. '\n        'Scored on post-switch accuracy and switch cost.'\n    )\n)\ndef ExecSwitch_Benchmark(llm, max_items: int = None):\n    results = []\n    df = df_switch.head(max_items) if max_items else df_switch\n\n    for _, row in df.iterrows():\n        item_id = row['item_id']\n        gold    = str(row['gold_action']).strip().upper()\n        meta    = row['gold_meta'] if isinstance(row['gold_meta'], dict) else {}\n        phase   = meta.get('phase', 'pre_switch')\n\n        prompt = (\n            f\"{row['prompt']}\\n\\n\"\n            \"--- OUTPUT FORMAT ---\\n\"\n            \"Return ONLY a valid JSON object (no extra text, no code fences) with keys:\\n\"\n            '  \"final_answer\", \"current_rule_name\", \"is_correct_rule_applied\" (bool), '\n            '\"confidence_score\" (0-100), \"reasoning\"'\n        )\n\n        raw     = llm.prompt(prompt)\n        cleaned = clean_json_response(raw)\n\n        try:\n            response = SwitchingSchema(**json.loads(cleaned))\n        except Exception as exc:\n            kbench.assertions.assert_true(False, expectation=f'[{item_id}] Parse error: {exc}')\n            results.append({'item_id': item_id, 'correct': False, 'phase': phase, 'confidence': 0})\n            continue\n\n        correct = response.final_answer.strip().upper() == gold\n\n        kbench.assertions.assert_true(\n            correct,\n            expectation=f'[{item_id}] [{phase}] Wrong answer. Got: {response.final_answer!r}. Expected: {gold!r}'\n        )\n\n        results.append({\n            'item_id': item_id,\n            'correct': correct,\n            'phase': phase,\n            'confidence': response.confidence_score,\n            'rule': response.current_rule_name,\n        })\n\n    pre  = [r for r in results if r.get('phase') == 'pre_switch']\n    post = [r for r in results if r.get('phase') == 'post_switch']\n    pre_acc  = sum(1 for r in pre if r.get('correct')) / len(pre) if pre else 0\n    post_acc = sum(1 for r in post if r.get('correct')) / len(post) if post else 0\n    print(f'[ExecSwitch_Benchmark] Pre-switch  Accuracy: {pre_acc:.2%} ({len(pre)} items)')\n    print(f'[ExecSwitch_Benchmark] Post-switch Accuracy: {post_acc:.2%} ({len(post)} items)')\n    print(f'[ExecSwitch_Benchmark] Switch Cost:          {pre_acc - post_acc:.2%}')\n\n    globals()['_last_execswitch_records'] = results\n    return None\n\nprint('✅ ExecSwitch_Benchmark defined')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-17T09:25:09.386504Z","iopub.execute_input":"2026-04-17T09:25:09.386927Z","iopub.status.idle":"2026-04-17T09:25:09.403798Z","shell.execute_reply.started":"2026-04-17T09:25:09.386897Z","shell.execute_reply":"2026-04-17T09:25:09.402693Z"}},"o